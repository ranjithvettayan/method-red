# RedTeam Agent — API Keys Configuration
# Copy this file to .env and fill in your keys.
# These keys are passed to containerized tools (subfinder, nuclei, etc.)

# ============================================
# Subfinder — passive subdomain enumeration
# More API keys = more sources = more subdomains found
# Get keys from each provider's website
# ============================================

# https://www.virustotal.com/gui/my-apikey
SUBFINDER_VIRUSTOTAL_API_KEY=

# https://securitytrails.com/app/account/credentials
SUBFINDER_SECURITYTRAILS_API_KEY=

# https://account.shodan.io/
SUBFINDER_SHODAN_API_KEY=

# https://chaos.projectdiscovery.io/
SUBFINDER_CHAOS_API_KEY=

# https://community.riskiq.com/login
SUBFINDER_PASSIVETOTAL_USERNAME=
SUBFINDER_PASSIVETOTAL_API_KEY=

# https://censys.io/account/api
SUBFINDER_CENSYS_API_ID=
SUBFINDER_CENSYS_API_SECRET=

# https://github.com/settings/tokens (public_repo scope)
SUBFINDER_GITHUB_TOKEN=

# https://intelx.io/account?tab=developer
SUBFINDER_INTELX_API_KEY=

# https://urlscan.io/user/profile
SUBFINDER_URLSCAN_API_KEY=

# ============================================
# Nuclei — vulnerability scanning
# ============================================

# https://cloud.projectdiscovery.io/
NUCLEI_PDCP_API_KEY=

# ============================================
# Other tools
# ============================================

# https://hunter.io/api_keys
HUNTER_API_KEY=

# https://fullhunt.io/
FULLHUNT_API_KEY=

# ============================================
# OSINT Agent — breach & DNS intelligence
# ============================================

# https://haveibeenpwned.com/API/Key
HIBP_API_KEY=

# https://securitytrails.com/app/account/credentials
# (shared with SUBFINDER_SECURITYTRAILS_API_KEY — set both to the same value)
SECURITYTRAILS_API_KEY=

# ============================================
# Metasploit RPC / OpenCode MCP (OpenCode only)
# ============================================

REDTEAM_RUNTIME_MODE=docker
MITMPROXY_PORT=8080
KATANA_LOCAL_BIN=/usr/local/bin/katana
KATANA_CHROME_BIN=/usr/bin/chromium
KATANA_HEADLESS_OPTIONS=--no-sandbox,--disable-dev-shm-usage,--disable-gpu
KATANA_MAX_FAILURE_COUNT=20
KATANA_STRATEGY=breadth-first

MSF_USER=msf
MSF_PASSWORD=msf
MSF_SERVER=127.0.0.1
MSF_PORT=55553
MSF_SSL=false
METASPLOIT_MCP_LOG_LEVEL=info
