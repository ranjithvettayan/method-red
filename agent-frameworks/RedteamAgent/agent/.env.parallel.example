# Parallel dispatch configuration — copy to .env or export before running.
# All values have sensible defaults; only override what you need.

# Max simultaneous batches in consume-test (default: 3)
# REDTEAM_MAX_PARALLEL_BATCHES=3

# Max instances of same agent type running at once (default: 2)
# REDTEAM_MAX_SAME_AGENT=2

# Cases per batch (default: 5)
# REDTEAM_BATCH_SIZE=5

# Phase 1 recon parallel agents (default: 2)
# REDTEAM_RECON_PARALLEL=2

# Phase 4 exploit parallel agents (default: 2)
# REDTEAM_EXPLOIT_PARALLEL=2

# Subagent task timeout in seconds (default: 300)
# REDTEAM_SUBAGENT_TIMEOUT=300
