# Runtime secrets and API keys for the single-image OpenCode container.
# Copy to .env and pass with: docker run --env-file docker/redteam-allinone/.env ...

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

REDTEAM_RUNTIME_MODE=local
KATANA_CHROME_BIN=/usr/bin/chromium
KATANA_HEADLESS_OPTIONS=--no-sandbox,--disable-dev-shm-usage,--disable-gpu
KATANA_MAX_FAILURE_COUNT=20
KATANA_STRATEGY=breadth-first
MSF_USER=msf
MSF_PASSWORD=msf
MSF_SERVER=127.0.0.1
MSF_PORT=55553
MSF_SSL=false
METASPLOIT_MCP_LOG_LEVEL=info
