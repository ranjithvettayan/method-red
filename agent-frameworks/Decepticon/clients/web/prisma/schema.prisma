generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Target types ─────────────────────────────────────────────────────
// Network/web attack surface targets supported by the self-hosted platform.

enum TargetType {
  web_url
  ip_range
}

enum EngagementStatus {
  draft
  planning
  running
  completed
  failed
}

// ── Application models ───────────────────────────────────────────────

model Engagement {
  id          String           @id @default(cuid())
  name        String
  targetType  TargetType
  targetValue String
  status      EngagementStatus @default(draft)

  // Self-hosted single-user mode — userId is always "local".
  userId      String           @default("local")

  // LangGraph thread tracking
  threadId      String?
  workspacePath String?

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId])
  @@index([status])
}
