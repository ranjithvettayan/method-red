classes: {
  action: {
    style: {
      fill: "#2b6cb0"
      stroke: "#bee3f8"
      font-color: "#bee3f8"
      border-radius: 5
    }
  }
  decision: {
    style: {
      fill: "#553c9a"
      stroke: "#e9d8fd"
      font-color: "#e9d8fd"
      border-radius: 5
    }
    shape: diamond
  }
  hardstop: {
    style: {
      fill: "#9b2c2c"
      stroke: "#feb2b2"
      font-color: "#feb2b2"
      border-radius: 5
      bold: true
    }
  }
  teammate: {
    style: {
      fill: "#2d3748"
      stroke: "#e2e8f0"
      font-color: "#e2e8f0"
      border-radius: 5
    }
  }
  done: {
    style: {
      fill: "#2f855a"
      stroke: "#c6f6d5"
      font-color: "#c6f6d5"
      border-radius: 5
      bold: true
    }
  }
  recovery: {
    style: {
      fill: "#744210"
      stroke: "#fefcbf"
      font-color: "#fefcbf"
      border-radius: 5
    }
  }
  phase: {
    style: {
      fill: "#1a202c"
      stroke: "#4a5568"
      font-color: "#a0aec0"
      border-radius: 8
    }
  }
}

direction: down

# ── Phase 1: Scope & Setup ──
setup: "Scope & Setup" {
  class: phase

  start: "attack TARGET" {class: action}
  scope: Gather scope + creds {class: action}
  init: "Init engagement dir + state.db\nSpawn state-mgr" {class: action}
  start -> scope -> init
}

# ── Phase 2: Reconnaissance ──
recon: Reconnaissance {
  class: phase

  scan-stop: "HARD STOP\nScan type?" {class: hardstop}
  nr: net-enum {class: teammate}
  record: "Message state-mgr:\nhosts + ports + services" {class: action}
  host-check: "Hostnames\nresolve?" {class: decision}
  host-stop: "HARD STOP\nhosts-update.sh" {class: hardstop}
  web-check: "HTTP/HTTPS\nports?" {class: decision}
  wd: web-enum {class: teammate}
  vhost-check: "Vhosts\nresolve?" {class: decision}
  no-http: "No HTTP →\ncontinue to\nattack surface" {class: action}

  scan-stop -> nr -> record -> host-check
  host-check -> host-stop: no
  host-stop -> host-check: operator fixes
  host-check -> web-check: yes
  web-check -> wd: yes
  web-check -> no-http: no
  wd -> vhost-check
  vhost-check -> host-stop: no
}

# ── Phase 3: Attack Surface ──
surface: "Categorize attack surface\nPresent chain analysis\nOperator picks path" {class: action}

# ── Phase 4: Discovery & Exploitation ──
exploit: "Discovery & Exploitation" {
  class: phase

  pick: "search_skills()\nResolve teammate" {class: action}
  assign: "Assign task to teammate\nwith skill + context" {class: action}
  run: "Teammate loads skill\n→ executes methodology\n→ messages state-mgr\n→ messages lead" {class: teammate}
  pick -> assign -> run
}

# ── Phase 5: Post-Task Checkpoint ──
post: "Post-Task Checkpoint" {
  class: phase

  parse: Read teammate summary {class: action}
  record-state: "Message state-mgr:\ncreds, vulns, access, pivots" {class: action}
  user-check: "New\nusernames?" {class: decision}
  parse -> record-state -> user-check
}

# ── Phase 6: Credential Spray Gate ──
spray: "Credential Spray Gate" {
  class: phase

  spray-stop: "HARD STOP\nShow usernames\n+ lockout policy" {class: hardstop}
  spray-check: "Spray\nintensity?" {class: decision}
  spray-tm: spray {class: teammate}
  record-creds: "Message state-mgr:\nvalid creds" {class: action}
  spray-stop -> spray-check
  spray-check -> spray-tm: light / medium / heavy
  spray-tm -> record-creds
}

# ── Execution Achieved ──
exec-achieved: "Execution Achieved" {
  class: phase

  shell: "Shell upgrade\nstart_listener or\nstart_process" {class: action}
  spawn-enum: "Spawn host enum teammate" {class: action}
  os: "OS?" {class: decision}
  lin: lin-enum {class: teammate}
  win: win-enum {class: teammate}
  ad-check: "Domain\naccount?" {class: decision}
  ad: ad-enum {class: teammate}

  shell -> spawn-enum -> os
  os -> lin: Linux
  os -> win: Windows
  ad-check -> ad: yes
}

# ── Phase 7: Chaining ──
chain: Chaining {
  class: phase

  analyze: "get_state_summary()\nAnalyze pivot map" {class: action}
  d1: "Unexploited\nvulns?" {class: decision}
  d2: "Shell without\nroot?" {class: decision}
  d3: "Untested\ncreds?" {class: decision}
  test-creds: "Spawn per-user enum teammate\nTest all access paths" {class: action}
  d4: "Uncracked\nhashes?" {class: decision}
  crack: recover {class: teammate}
  d5: "Pivot\npaths?" {class: decision}
  pivot-tm: pivot {class: teammate}
  d6: "Objectives\nmet?" {class: decision}

  analyze -> d1
  d1 -> d2: no
  d2 -> d3: no
  d3 -> test-creds: yes
  d3 -> d4: no
  d4 -> crack: yes
  crack -> analyze
  d4 -> d5: no
  d5 -> pivot-tm: yes
  pivot-tm -> analyze: "tunnel established\n→ recon internal"
  d5 -> d6: no
}

# ── Recovery ──
recovery: "Recovery Paths" {
  class: phase

  av: bypass {class: recovery}
  clock: "HARD STOP\nclock-sync.sh" {class: hardstop}
  research-tm: research {class: recovery}
  blocked: "Message state-mgr:\nadd_blocked\nnext vector" {class: action}
  av -> blocked: no bypass
  research-tm -> blocked: no vector
}

# ── Post-Exploitation ──
post-exploit: "Collect evidence\nUpdate state\nVerify objectives" {class: action}

# ── End ──
complete: Engagement Complete {class: done}
retro: "retrospective\n→ skill improvements" {class: recovery}

# ═══ Cross-phase connections ═══

setup -> recon

# Recon exits
recon.no-http -> surface
recon.vhost-check -> surface: yes

surface -> exploit

exploit -> post
post.user-check -> spray: yes
post.user-check -> chain.analyze: no

spray.spray-check -> chain.analyze: skip
spray.record-creds -> chain.analyze

# Chaining loops
chain.d1 -> exploit.pick: yes {style.stroke-dash: 3}
chain.d2 -> exec-achieved.shell: yes
chain.test-creds -> exploit.pick {style.stroke-dash: 3}

# Execution achieved flows
exec-achieved.os -> ad-check: Windows
exec-achieved.lin -> post.parse {style.stroke-dash: 3}
exec-achieved.win -> post.parse {style.stroke-dash: 3}
exec-achieved.ad -> post.parse {style.stroke-dash: 3}
exec-achieved.ad-check -> post.parse: no {style.stroke-dash: 3}

# Recovery
exploit.run -> recovery.av: AV blocked {style.stroke-dash: 3}
exploit.run -> recovery.clock: clock skew {style.stroke-dash: 3}
exploit.run -> recovery.research-tm: unknown vector {style.stroke-dash: 3}
recovery.av -> exploit.assign: bypass {style.stroke-dash: 3}
recovery.blocked -> chain.analyze {style.stroke-dash: 3}
recovery.clock -> exploit.assign: synced {style.stroke-dash: 3}

# End
chain.d6 -> post-exploit: yes
chain.d6 -> complete: no — exhausted
post-exploit -> complete
complete -> retro: {style.stroke-dash: 3}
